{
  "name": "ytdl-site",
  "version": "1.0.0",
  "description": "YouTube Video & Audio Downloader",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "node -e \"if(!process.env.RAILWAY_ENVIRONMENT) { require('child_process').execSync('node setup.js', {stdio:'inherit'}); }\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
